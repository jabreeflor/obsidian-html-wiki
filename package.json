{
  "name": "obsidian-html-wiki",
  "version": "1.0.0",
  "description": "Turn any Obsidian vault into a browsable HTML wiki, in real time, with no export step.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "prebuild": "node scripts/ensure-client-bundle.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "pretest": "node scripts/ensure-client-bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prelint": "node scripts/ensure-client-bundle.mjs",
    "lint": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "wiki",
    "html"
  ],
  "author": "Jabree Flor",
  "license": "MIT",
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "undici": "^7.0.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.15",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.14.0",
    "minisearch": "^7.1.1"
  }
}
